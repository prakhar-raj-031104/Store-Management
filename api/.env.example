# ---- API ----
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- Database ----
# Local dev (docker compose Postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/storeapp?schema=public"
# Production (Neon): copy the connection string from the Neon dashboard and
# keep the ?sslmode=require parameter — Neon refuses non-TLS connections, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/storeapp?sslmode=require"

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Public base URL used when generating QR codes (points at the web app)
PUBLIC_WEB_URL=http://localhost:5173
